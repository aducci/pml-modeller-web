generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  plan          Plan      @default(FREE)
  stripeId      String?   @unique
  projects      Project[]  @relation("ProjectOwner")
  projectsCreated Project[] @relation("ProjectCreatedBy")
  projectsUpdated Project[] @relation("ProjectUpdatedBy")
  projectFilesCreated ProjectFile[] @relation("ProjectFileCreatedBy")
  projectFilesUpdated ProjectFile[] @relation("ProjectFileUpdatedBy")
  subscription  Subscription?
  usage         UsageRecord[]
  organizationMemberships OrganizationMember[]
  ownedOrganizations      Organization[]      @relation("OrganizationOwner")
  promptSkillVersionsAuthored PromptSkillVersion[]
  findingCopyUpdates          FindingCopy[]
  validationRuleUpdates       ValidationRule[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id            String               @id @default(cuid())
  name          String
  slug          String?              @unique
  isPersonal    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  ownerUserId   String?
  ownerUser     User?                @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  members       OrganizationMember[]
  projects      Project[]
  snapshots     Snapshot[]
  subscriptions Subscription[]
  usage         UsageRecord[]
  conversations Conversation[]
  promptSkills  PromptSkill[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(VIEWER)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  pmlSource   String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  organizationId String?
  user        User      @relation("ProjectOwner", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdByUserId String?
  updatedByUserId String?
  createdByUser   User?     @relation("ProjectCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?     @relation("ProjectUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  isPublic    Boolean   @default(false)
  snapshots   Snapshot[]
  conversations Conversation[]
  files       ProjectFile[]

  @@index([organizationId, updatedAt])
}

// Project.pmlSource above is deprecated as of the ProjectFile model — a
// project is now a workspace containing one or more files, each with its
// own pmlSource. Left in place (unused going forward) rather than dropped,
// since dropping a column is irreversible; a follow-up migration can remove
// it once this model has been live and verified.
model ProjectFile {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  pmlSource       String    @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdByUserId String?
  updatedByUserId String?
  createdByUser   User?     @relation("ProjectFileCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?     @relation("ProjectFileUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([projectId, updatedAt])
}

model Snapshot {
  id          String    @id @default(cuid())
  projectId   String
  organizationId String?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  pmlSource   String    @db.Text
  label       String?
  createdAt   DateTime  @default(now())

  @@index([organizationId, createdAt])
}

model Subscription {
  id                 String     @id @default(cuid())
  userId             String     @unique
  organizationId     String?
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  stripeSubId        String     @unique
  stripePriceId      String
  status             SubStatus  @default(TRIALING)
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean    @default(false)

  @@index([organizationId])
}

model UsageRecord {
  id        String    @id @default(cuid())
  userId    String
  organizationId String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  type      UsageType
  createdAt DateTime  @default(now())
  metadata  Json?

  @@index([organizationId, createdAt])
}

model Conversation {
  id            String                 @id @default(cuid())
  projectId     String
  organizationId String?
  title         String                 @default("New Chat")
  mode          String?                @default("guided")
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  project       Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization  Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  messages      ConversationMessage[]

  @@index([organizationId, updatedAt])
  @@index([projectId])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String       @db.Text
  metadata       Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Structured, versioned storage for the AI's "skill" prompts (system prompt,
// chat prompt, etc.) — previously hardcoded template-literal exports in
// lib/ai/prompts.ts, editable only via a code change + redeploy. Seeded from
// those exact strings on migration so behavior is unchanged on day one; see
// lib/ai/skillPrompts.ts for the resolution layer that reads these at
// request time (with a fallback to the original hardcoded defaults if a row
// is missing or the DB is unreachable).
//
// organizationId is nullable and unused today (every row is a global
// platform default, edited only via the super-admin-gated /admin/skills
// tab — see lib/superAdmin.ts). It's here so a future per-tenant skill
// override doesn't need a schema migration: a non-null organizationId row
// would simply take precedence over the global (null) one for that org.
model PromptSkill {
  id             String              @id @default(cuid())
  key            String
  organizationId String?
  description    String?
  createdAt      DateTime            @default(now())
  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions       PromptSkillVersion[]

  @@unique([key, organizationId])
  @@index([organizationId])
}

model PromptSkillVersion {
  id            String      @id @default(cuid())
  skillId       String
  content       String      @db.Text
  label         String?
  createdAt     DateTime    @default(now())
  createdByUserId String?
  skill         PromptSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdByUser User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([skillId, createdAt])
}

// User-facing wording for a deterministic Finding (computeProcessSuggestions'
// diagnostic `code`, e.g. TASK_NO_ACTOR) — kept separate from PromptSkill
// since this is two short structured fields per code, not one prompt blob,
// and there's no need for version history on a one-line label. One row per
// code is the current value; missing rows fall back to the hardcoded
// defaults in lib/ai/findingCopy.ts (same "seed from code, DB overrides"
// shape PromptSkill uses). Keying on `code` rather than a synthetic id means
// a future rules-framework addition (new diagnostic codes) gets an
// admin-editable title/summary slot automatically, no migration needed.
model FindingCopy {
  code            String   @id
  title           String
  summary         String
  updatedAt       DateTime @updatedAt
  updatedByUserId String?
  updatedByUser   User?    @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)
}

// Admin-editable override for one rule in pml-core's rule-shape framework
// (contractGuards.ts's RuleConfig/DEFAULT_RULE_CONFIGS — see that file's
// comment for the shape/predicate design). `params` stores the full
// RuleConfig as JSON (not just `enabled`) so this table doesn't need a
// second migration when the admin UI grows from "toggle a rule on/off"
// (phase one) to editing individual parameters (threshold, predicate,
// message template) later — the JSON blob's shape is already rich enough.
// Missing rows fall back to DEFAULT_RULE_CONFIGS entirely (same "seed from
// code, DB overrides" shape as FindingCopy/PromptSkill above). Keyed on
// `code`, same reasoning as FindingCopy: a rule added to a shape the engine
// already supports needs no schema change to become admin-editable.
model ValidationRule {
  code            String   @id
  enabled         Boolean  @default(true)
  params          Json?
  updatedAt       DateTime @updatedAt
  updatedByUserId String?
  updatedByUser   User?    @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum UsageType {
  AI_CALL
  EXPORT
  DIAGRAM_RENDER
}

enum OrganizationRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}
