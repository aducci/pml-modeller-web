generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  plan          Plan      @default(FREE)
  stripeId      String?   @unique
  projects      Project[]  @relation("ProjectOwner")
  projectsCreated Project[] @relation("ProjectCreatedBy")
  projectsUpdated Project[] @relation("ProjectUpdatedBy")
  subscription  Subscription?
  usage         UsageRecord[]
  organizationMemberships OrganizationMember[]
  ownedOrganizations      Organization[]      @relation("OrganizationOwner")
}

model Organization {
  id            String               @id @default(cuid())
  name          String
  slug          String?              @unique
  isPersonal    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  ownerUserId   String?
  ownerUser     User?                @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  members       OrganizationMember[]
  projects      Project[]
  snapshots     Snapshot[]
  subscriptions Subscription[]
  usage         UsageRecord[]
  conversations Conversation[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(VIEWER)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  pmlSource   String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  organizationId String?
  user        User      @relation("ProjectOwner", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdByUserId String?
  updatedByUserId String?
  createdByUser   User?     @relation("ProjectCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?     @relation("ProjectUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  isPublic    Boolean   @default(false)
  snapshots   Snapshot[]
  conversations Conversation[]

  @@index([organizationId, updatedAt])
}

model Snapshot {
  id          String    @id @default(cuid())
  projectId   String
  organizationId String?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  pmlSource   String    @db.Text
  label       String?
  createdAt   DateTime  @default(now())

  @@index([organizationId, createdAt])
}

model Subscription {
  id                 String     @id @default(cuid())
  userId             String     @unique
  organizationId     String?
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  stripeSubId        String     @unique
  stripePriceId      String
  status             SubStatus  @default(TRIALING)
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean    @default(false)

  @@index([organizationId])
}

model UsageRecord {
  id        String    @id @default(cuid())
  userId    String
  organizationId String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  type      UsageType
  createdAt DateTime  @default(now())
  metadata  Json?

  @@index([organizationId, createdAt])
}

model Conversation {
  id            String                 @id @default(cuid())
  projectId     String
  organizationId String?
  title         String                 @default("New Chat")
  mode          String?                @default("guided")
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  project       Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization  Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  messages      ConversationMessage[]

  @@index([organizationId, updatedAt])
  @@index([projectId])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String       @db.Text
  metadata       Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum UsageType {
  AI_CALL
  EXPORT
  DIAGRAM_RENDER
}

enum OrganizationRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}
