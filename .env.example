# Database
DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth Configuration
# Generate secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://yourdomain.com

# OAuth Providers
GOOGLE_ID=
GOOGLE_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# AI/LLM Integration (Anthropic)
ANTHROPIC_API_KEY=

# Stripe (if using billing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Site-wide password gate (optional)
# If set, the entire site will require this password before access
# Do NOT commit the actual password to version control
SITE_PASSWORD=

# Cookie secret for signing site access tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Do NOT commit the actual secret to version control
COOKIE_SECRET=

# Platform super-admin allowlist (comma-separated emails).
# Gates /admin (Theme, Layout, Skills) — global tool config, not any one
# tenant's data. See src/lib/superAdmin.ts.
SUPER_ADMIN_EMAILS=
